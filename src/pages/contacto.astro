---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto">
  <div class="bg-linear-to-br from-primary-dark to-primary pt-24 pb-12 px-6 relative rounded-b-[50%_10%]">
    <div class="container max-w-300 mx-auto text-center">
      <h1 class="text-[2.5rem] md:text-[3.5rem] text-white font-main font-semibold leading-tight m-0">Contacto</h1>
      <p class="text-xl text-white/90 mt-4">Nos encantará ayudarte a crear el detalle perfecto</p>
    </div>
  </div>

  <section class="py-16 px-6">
    <div class="container max-w-300 mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 mt-8">
      
      <!-- Información de Contacto -->
      <div class="animate-fade-in">
        <h2 class="text-[2rem] text-text-main font-main font-semibold mb-4">¿Listo para tu pedido?</h2>
        <p class="mb-8 text-text-muted">También puedes enviarnos un mensaje directo para pedidos personalizados, estaremos encantados de atenderte.</p>
        
        <div class="flex flex-col gap-6">
          <div class="flex items-center gap-5">
            <span class="text-[1.8rem] bg-primary-light w-12.5 h-12.5 flex items-center justify-center rounded-full">📱</span>
            <div>
              <strong class="text-[1.1rem] text-text-main font-main font-semibold">WhatsApp / Teléfono</strong>
              <p class="text-[0.9rem] text-text-muted m-0">998 181 2411</p>
            </div>
          </div>
          
          <div class="flex items-center gap-5">
            <span class="text-[1.8rem] bg-primary-light w-12.5 h-12.5 flex items-center justify-center rounded-full">📍</span>
            <div>
              <strong class="text-[1.1rem] text-text-main font-main font-semibold">Ubicación</strong>
              <p class="text-[0.9rem] text-text-muted m-0">Cancún, Quintana Roo</p>
            </div>
          </div>

          <div class="flex items-center gap-5">
            <span class="text-[1.8rem] bg-primary-light w-12.5 h-12.5 flex items-center justify-center rounded-full">📩</span>
            <div>
              <strong class="text-[1.1rem] text-text-main font-main font-semibold">Atención Personalizada</strong>
              <p class="text-[0.9rem] text-text-muted m-0">Para pedidos y cotizaciones</p>
            </div>
          </div>
        </div>

        <div class="mt-12">
          <h4 class="mb-4 font-main font-semibold">Síguenos</h4>
          <div class="flex gap-4">
            <a href="#" class="btn btn-outline py-2 px-4">Facebook</a>
            <a href="#" class="btn btn-outline py-2 px-4">Instagram</a>
          </div>
        </div>
      </div>

      <!-- Formulario de Contacto -->
      <div class="p-10 rounded-3xl glass animate-fade-in" style="animation-delay: 0.2s;">
        <h3 class="mb-6 text-primary-dark text-2xl font-main font-semibold">Envíanos un mensaje</h3>
        <form>
          <div class="mb-6">
            <label for="nombre" class="block mb-2 font-medium">Nombre</label>
            <input type="text" id="nombre" placeholder="Tu nombre" class="w-full py-3 px-4 border border-black/10 rounded-lg font-inherit transition-all duration-300 bg-white/80 focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/30" required />
          </div>
          
          <div class="mb-6">
            <label for="email" class="block mb-2 font-medium">Email</label>
            <input type="email" id="email" placeholder="tu@email.com" class="w-full py-3 px-4 border border-black/10 rounded-lg font-inherit transition-all duration-300 bg-white/80 focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/30" required />
          </div>
          
          <div class="mb-6">
            <label for="mensaje" class="block mb-2 font-medium">Mensaje</label>
            <textarea id="mensaje" rows="5" placeholder="¿En qué te podemos ayudar?" class="w-full py-3 px-4 border border-black/10 rounded-lg font-inherit transition-all duration-300 bg-white/80 focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/30" required></textarea>
          </div>
          
          <button type="submit" class="btn btn-primary w-full">Enviar Mensaje</button>
        </form>
      </div>

    </div>
  </section>
</Layout>
