---
const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/catalogo", label: "Catálogo" },
  { href: "/personalizacion", label: "Personalizar" },
  { href: "/galeria", label: "Galería" },
];
const socialLinks = [
  { 
    label: "Instagram", 
    href: "#!", 
    color: "group-hover:bg-gradient-to-tr group-hover:from-[#f9ce34] group-hover:via-[#ee2a7b] group-hover:to-[#6228d7]", 
    icon: `<path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.9 3.9 0 0 0-1.417.923A3.9 3.9 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.9 3.9 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.9 3.9 0 0 0-.923-1.417A3.9 3.9 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599s.453.546.598.92c.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.5 2.5 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.5 2.5 0 0 1-.92-.598 2.5 2.5 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233s.008-2.388.046-3.231c.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92s.546-.453.92-.598c.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92m-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217m0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334"></path>` 
  },
  { 
    label: "TikTok", 
    href: "#!", 
    color: "group-hover:bg-[#000000]", 
    icon: `<path d="M9 0h1.98c.144.715.54 1.617 1.235 2.512C12.895 3.389 13.797 4 15 4v2c-1.753 0-3.07-.814-4-1.829V11a5 5 0 1 1-5-5v2a3 3 0 1 0 3 3V0Z"></path>` 
  }
];
---

<footer class="bg-primary-dark text-white pt-16">
  <div class="container max-w-300 mx-auto px-6 grid grid-cols-1 md:grid-cols-[2fr_1fr_1fr_1fr] gap-12 mb-12">
    <div class="flex flex-col">
      <a href="/" class="flex flex-col md:flex-row md:items-baseline md:gap-2">
        <span class="font-accent text-white text-2xl md:text-3xl leading-none">Vitalis</span>
        <span class="font-accent text-white text-2xl md:text-3xl leading-none">Glamour</span>
      </a>
      <p class="mt-4 opacity-90 max-w-75">Flores que no se marchitan, hechas con creatividad y amor directamente desde Cancún.</p>
    </div>
    <div>
      <h4 class="font-main font-semibold text-xl text-white mb-6">Enlaces Rápidos</h4>
      <ul class="list-none p-0 flex flex-col gap-3 font-text">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="opacity-80 transition-all duration-300 hover:opacity-100 hover:pl-2">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
    <div>
      <h4 class="font-main font-semibold text-xl text-white mb-6">Síguenos</h4>
      <div class="flex gap-4">
        {socialLinks.map((social) => (
          <div class="relative group">
            <div class="absolute -top-10 left-1/2 -translate-x-1/2 px-3 py-1 bg-white text-primary-dark text-xs font-bold rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible group-hover:-top-12 transition-all duration-300 shadow-lg after:content-[''] after:absolute after:top-full after:left-1/2 after:-translate-x-1/2 after:border-8 after:border-transparent after:border-t-white">
              {social.label}
            </div>
            <a href="#!" onclick="return false;" aria-label={social.label} class="relative w-12 h-12 flex items-center justify-center bg-white/10 rounded-full overflow-hidden transition-all duration-300 group-hover:shadow-2xl group-hover:text-white">
              <div class={`absolute bottom-0 left-0 w-full h-0 transition-all duration-300 ease-in-out group-hover:h-full ${social.color}`}></div>
              <svg class="relative z-10 w-5 h-5 fill-current transition-colors duration-300 group-hover:text-white" viewBox="0 0 16 16" set:html={social.icon}/>
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>
  <div class="bg-black/5 text-center p-6 text-sm opacity-80">
    <p>&copy; {new Date().getFullYear()} Flores Eternas Cancún. Todos los derechos reservados.</p>
  </div>
</footer>
