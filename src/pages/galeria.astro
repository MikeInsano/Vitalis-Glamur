---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import mama from '../assets/galeria/mama.webp';
import diego from '../assets/galeria/diego.webp';
import ramo1 from '../assets/galeria/ramo1.webp';
import ramo2 from '../assets/galeria/ramo2.webp';
const fotosRamos = [
  { img: mama, alt: "Cumpleaños" },
  { img: diego, alt: "Detalle de tulipan eterno" },
  { img: ramo1, alt: "Tulipan y Dalia eternos" },
  { img: ramo2, alt: "Arreglo personalizado" },
];
---

<Layout title="Galería">
  <div class="bg-linear-to-br from-primary-dark to-primary pt-24 pb-12 px-6 relative rounded-b-[50%_10%]">
    <div class="container max-w-300 mx-auto text-center">
      <h1 class="text-[2.5rem] md:text-[3.5rem] text-white font-main font-semibold leading-tight m-0">Nuestra Galería</h1>
      <p class="text-xl text-white/90 mt-4">Un vistazo al amor en cada detalle</p>
    </div>
  </div>
  <section class="py-16 px-6">
    <div class="container max-w-6xl mx-auto">
      <div class="columns-1 sm:columns-2 lg:columns-5 gap-4 space-y-4 animate-fade-in">
        {fotosRamos.map((foto) => (
          <div class="break-inside-avoid group relative rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 border border-black/5 cursor-zoom-in">
            <Image src={foto.img} alt={foto.alt} width={400} class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"/>
            <div class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-end p-4">
              <span class="text-white font-accent text-lg translate-y-2 group-hover:translate-y-0 transition-all duration-500">
                {foto.alt}
              </span>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-16 flex flex-col items-center">
        <div class="w-16 h-0.5 bg-primary/20 rounded-full mb-6"></div>
        <p class="font-main text-text-muted text-base mb-6 text-center italic">¿Tienes una idea propia? La hacemos realidad.</p>
        <a href="/personalizacion" class="btn btn-primary py-2.5! px-6! text-sm! shadow-md">
          Personalizar mi Ramo
        </a>
      </div>
    </div>
  </section>
</Layout>
