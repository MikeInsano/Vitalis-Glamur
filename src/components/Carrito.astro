<div id="cart-overlay" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-90 hidden opacity-0 transition-opacity duration-500"></div>
<div id="cart-sidebar" class="fixed top-0 right-0 w-full sm:w-100 h-screen bg-white z-100 shadow-2xl transition-transform duration-500 translate-x-full flex flex-col">
    <div class="p-6 border-b border-gray-100 flex justify-between items-start bg-[#fff5f7]">
        <div class="flex flex-col">
            <h2 class="text-2xl font-main font-bold text-primary-dark tracking-tight leading-none">Tu Carrito</h2>
            <button id="clear-cart" class="text-left text-[10px] uppercase tracking-widest text-primary font-bold hover:text-primary-dark transition-all duration-300 cursor-pointer mt-2 hidden">
                Vaciar Carrito
            </button>
        </div>
        <button id="close-cart" class="text-gray-400 hover:text-primary transition-colors p-1 cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
    </div>
    <div id="cart-items-container" class="flex-1 overflow-y-auto p-6 space-y-4">
        <p class="text-center text-gray-400 italic py-10 font-main text-sm">Cargando tus flores...</p>
    </div>
    <div class="p-6 border-t border-gray-100 space-y-4 bg-gray-50">
        <div class="flex justify-between items-center text-xl font-bold text-text-main">
            <span class="font-main text-lg">Total:</span>
            <span id="cart-total-amount" class="text-primary-dark">$0 MXN</span>
        </div>
        <button id="whatsapp-checkout" class="w-full btn btn-primary py-4 flex items-center justify-center gap-2 shadow-lg shadow-primary/20 cursor-pointer font-bold">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            Confirmar Pedido
        </button>
    </div>
</div>
<script>
    interface ProductoCarrito {
        nombre: string;
        precio: number;
        cantidad: number;
    }

    let carrito: ProductoCarrito[] = JSON.parse(localStorage.getItem('cart') || '[]');
    const telefonoWhatsApp = "529988263650";
    let confirmandoVaciar = false;
    const sidebar = document.getElementById('cart-sidebar');
    const overlay = document.getElementById('cart-overlay');
    const container = document.getElementById('cart-items-container');
    const totalEl = document.getElementById('cart-total-amount');
    const clearBtn = document.getElementById('clear-cart');

    function actualizarInterfaz() {
        const contadorEls = document.querySelectorAll('.cart-count');
        const totalItems = carrito.reduce((acc, prod) => acc + prod.cantidad, 0);
        contadorEls.forEach(el => el.textContent = totalItems.toString());
        localStorage.setItem('cart', JSON.stringify(carrito));
        if (!container || !totalEl || !clearBtn) return;
        confirmandoVaciar = false;
        clearBtn.textContent = "Vaciar Carrito";
        clearBtn.classList.remove('text-red-500');
        if (carrito.length === 0) {
            container.innerHTML = `<p class="text-center text-gray-400 italic py-10 font-main">Tu carrito está vacío...</p>`;
            totalEl.textContent = `$0 MXN`;
            clearBtn.classList.add('hidden');
        } else {
            let total = 0;
            clearBtn.classList.remove('hidden');
            container.innerHTML = carrito.map((item, index) => {
                const subtotal = item.precio * item.cantidad;
                total += subtotal;
                return `
                <div class="flex justify-between items-center bg-white p-4 rounded-2xl border border-gray-100 shadow-sm animate-fade-in">
                    <div class="flex-1">
                        <h4 class="font-bold text-text-main font-main text-base leading-tight">${item.nombre}</h4>
                        <p class="text-xs text-primary font-bold mt-1">$${item.precio} MXN</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <button class="w-7 h-7 rounded-full border border-gray-200 flex items-center justify-center hover:bg-primary hover:text-white transition-colors minus-btn cursor-pointer" data-index="${index}">-</button>
                        <span class="font-bold text-sm min-w-[20px] text-center">${item.cantidad}</span>
                        <button class="w-7 h-7 rounded-full border border-gray-200 flex items-center justify-center hover:bg-primary hover:text-white transition-colors plus-btn cursor-pointer" data-index="${index}">+</button>
                    </div>
                </div>
                `;
            }).join('');
            
            totalEl.textContent = `$${total} MXN`;
            document.querySelectorAll('.minus-btn').forEach(b => {
                b.addEventListener('click', (e) => {
                    const idx = parseInt((e.currentTarget as HTMLButtonElement).dataset.index!);
                    modificarCantidad(idx, -1);
                });
            });
            document.querySelectorAll('.plus-btn').forEach(b => {
                b.addEventListener('click', (e) => {
                    const idx = parseInt((e.currentTarget as HTMLButtonElement).dataset.index!);
                    modificarCantidad(idx, 1);
                });
            });
        }
    }

    function modificarCantidad(index: number, cambio: number) {
        carrito[index].cantidad += cambio;
        if (carrito[index].cantidad <= 0) {
            carrito.splice(index, 1);
        }
        actualizarInterfaz();
    }

    function manejarVaciarCarrito() {
        if (!clearBtn || carrito.length === 0) return;
        if (!confirmandoVaciar) {
            confirmandoVaciar = true;
            clearBtn.textContent = "Click de nuevo para vaciar";
            clearBtn.classList.add('text-red-500', 'scale-105');
            setTimeout(() => {
                if (confirmandoVaciar) {
                    confirmandoVaciar = false;
                    clearBtn.textContent = "Vaciar Carrito";
                    clearBtn.classList.remove('text-red-500');
                }
            }, 5000);
        } else {
            carrito = [];
            actualizarInterfaz();
        }
    }

    function toggleCart() {
        if (!sidebar || !overlay) return;
        const isOpening = sidebar.classList.contains('translate-x-full');
        sidebar.classList.toggle('translate-x-full');
        overlay.classList.toggle('hidden');
        setTimeout(() => overlay.classList.toggle('opacity-100'), 10);
        document.body.classList.toggle('overflow-hidden');
        if (isOpening) actualizarInterfaz();
    }

    document.addEventListener('DOMContentLoaded', () => {
        actualizarInterfaz();
        window.addEventListener('add-to-cart', (e: any) => {
            const { nombre, precio } = e.detail;
            const existente = carrito.find(p => p.nombre === nombre);
            if (existente) {
                existente.cantidad++;
            } else {
                carrito.push({ nombre, precio, cantidad: 1 });
            }
            actualizarInterfaz();
        });
        document.querySelector('button[aria-label="Abrir carrito"]')?.addEventListener('click', toggleCart);
        document.getElementById('close-cart')?.addEventListener('click', toggleCart);
        overlay?.addEventListener('click', toggleCart);
        clearBtn?.addEventListener('click', manejarVaciarCarrito);
        document.getElementById('whatsapp-checkout')?.addEventListener('click', () => {
            if (carrito.length === 0) return;
            let total = 0;
            let msg = "*NUEVO PEDIDO - VITALIS GLAMUR*\n";
            msg += "--------------------------------\n\n";
            carrito.forEach(item => {
                const sub = item.precio * item.cantidad;
                total += sub;
                msg += `• *${item.cantidad}x* ${item.nombre} - _$${sub} MXN_\n`;
            });
            msg += `\n--------------------------------\n`;
            msg += `*TOTAL: $${total} MXN*\n\n`;
            msg += `¿Me confirmas disponibilidad para estos ramos?`;
            window.open(`https://wa.me/${telefonoWhatsApp}?text=${encodeURIComponent(msg)}`, '_blank');
        });
    });
</script>