---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto">
  <div class="page-header text-center">
    <div class="container">
      <h1 class="title" style="color: white; margin-bottom: 0;">Contacto</h1>
      <p class="subtitle" style="color: rgba(255,255,255,0.9); margin-top: 1rem;">Nos encantará ayudarte a crear el detalle perfecto 🌸</p>
    </div>
  </div>

  <section class="section">
    <div class="container contact-grid">
      
      <!-- Información de Contacto -->
      <div class="contact-info animate-fade-in">
        <h2 class="title" style="font-size: 2rem;">¿Listo para tu pedido?</h2>
        <p style="margin-bottom: 2rem; color: var(--c-text-muted);">También puedes enviarnos un mensaje directo para pedidos personalizados, estaremos encantados de atenderte.</p>
        
        <div class="info-items">
          <div class="item">
            <span class="icon">📱</span>
            <div>
              <strong>WhatsApp / Teléfono</strong>
              <p>998 181 2411</p>
            </div>
          </div>
          
          <div class="item">
            <span class="icon">📍</span>
            <div>
              <strong>Ubicación</strong>
              <p>Cancún, Quintana Roo</p>
            </div>
          </div>

          <div class="item">
            <span class="icon">📩</span>
            <div>
              <strong>Atención Personalizada</strong>
              <p>Para pedidos y cotizaciones</p>
            </div>
          </div>
        </div>

        <div class="social-links" style="margin-top: 3rem;">
          <h4 style="margin-bottom: 1rem;">Síguenos</h4>
          <div class="links">
            <a href="#" class="btn btn-outline" style="padding: 0.5rem 1rem;">Facebook</a>
            <a href="#" class="btn btn-outline" style="padding: 0.5rem 1rem;">Instagram</a>
          </div>
        </div>
      </div>

      <!-- Formulario de Contacto -->
      <div class="contact-form glass animate-fade-in" style="animation-delay: 0.2s;">
        <h3 style="margin-bottom: 1.5rem; color: var(--c-primary-dark); font-size: 1.5rem;">Envíanos un mensaje</h3>
        <form>
          <div class="form-group">
            <label for="nombre">Nombre</label>
            <input type="text" id="nombre" placeholder="Tu nombre" required />
          </div>
          
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" placeholder="tu@email.com" required />
          </div>
          
          <div class="form-group">
            <label for="mensaje">Mensaje</label>
            <textarea id="mensaje" rows="5" placeholder="¿En qué te podemos ayudar?" required></textarea>
          </div>
          
          <button type="submit" class="btn btn-primary" style="width: 100%;">Enviar Mensaje</button>
        </form>
      </div>

    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--c-primary), #FF8FAB);
    padding: 6rem 1.5rem 3rem;
    position: relative;
    border-bottom-left-radius: 50% 10%;
    border-bottom-right-radius: 50% 10%;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .info-items {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .item {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .item .icon {
    font-size: 1.8rem;
    background: var(--c-primary-light);
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }

  .item strong {
    font-size: 1.1rem;
    color: var(--c-text-main);
  }

  .item p {
    color: var(--c-text-muted);
    font-size: 0.9rem;
    margin: 0;
  }

  .links {
    display: flex;
    gap: 1rem;
  }

  .contact-form {
    padding: 2.5rem;
    border-radius: var(--radius-lg);
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.8rem 1rem;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: var(--radius-sm);
    font-family: inherit;
    transition: var(--transition);
    background-color: rgba(255, 255, 255, 0.8);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--c-primary);
    box-shadow: 0 0 0 3px rgba(255, 183, 178, 0.3);
  }
</style>
