---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import cumple from '../assets/galeria/mama.webp';
import Rapunzel from '../assets/galeria/ramoRapunzel.webp';
import Lirios from '../assets/galeria/lirios.webp';
---

<Layout title="Inicio">
  <section class="min-h-screen flex items-center relative pt-20">
    <div class="absolute inset-0 -z-10 bg-bg" style="background: radial-gradient(circle at top right, #FFDADE 0%, transparent 60%), radial-gradient(circle at bottom left, #E2F0CB 0%, transparent 50%), #FAFAFA;"></div>
    <div class="container max-w-300 mx-auto px-6 flex justify-center items-center animate-fade-in">
      <div class="glass max-w-200 p-8 md:p-12 rounded-3xl text-center">
        <h1 class="text-[2.2rem] md:text-5xl mb-6 text-text-main font-main font-semibold leading-[1.1]">
          Flores que no se marchitan, hechas con 
          <span class="font-accent italic text-accent relative inline-block px-1">
            creatividad
            <div class="absolute bottom-1 left-0 w-full h-1.5 bg-primary/50 -z-10 rounded-full"></div>
          </span> 
          y 
          <span class="font-accent italic text-accent relative inline-block px-1">
            amor
            <div class="absolute bottom-1 left-0 w-full h-1.5 bg-primary/50 -z-10 rounded-full"></div>
          </span>
        </h1>
        <p class="text-lg text-text-muted mb-8">Transformamos limpiapipas en detalles únicos y duraderos.</p>
        <div class="flex justify-center gap-4 flex-wrap">
          <a href="/catalogo" class="btn btn-primary">Ver catálogo</a>
          <a href="#destacados" class="btn btn-outline">Explorar</a>
        </div>
      </div>
    </div>
  </section>
  <section id="destacados" class="py-16 px-6 bg-secondary/20">
    <div class="container max-w-300 mx-auto text-center">
      <h2 class="text-[2.5rem] md:text-[3.5rem] mb-4 text-text-main font-main font-semibold leading-tight">Nuestros Favoritos</h2>
      <p class="text-xl text-text-muted font-normal mb-12">Un vistazo a las creaciones que más enamoran</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 rounded-2xl transition-all duration-300 hover:-translate-y-1.5 hover:shadow-lg glass">
          <div class="h-60 rounded-xl mb-5 overflow-hidden shadow-inner relative">
            <Image src={cumple} alt="Ramo eterno personalizado para regalo de cumpleaños" width={300} height={300} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"/>
            <div class="absolute inset-0 bg-linear-to-t from-black/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>
          <h3 class="mb-2 font-main font-semibold text-xl">Ramo de Cumpleaños</h3>
          <p class="text-text-muted text-base font-light">El detalle sorpresa ideal para que su día especial dure para siempre.</p>
        </div>
        <div class="p-6 rounded-2xl transition-all duration-300 hover:-translate-y-1.5 hover:shadow-lg glass">
          <div class="h-60 rounded-xl mb-5 overflow-hidden shadow-inner relative">
            <Image src={Rapunzel} alt="Diseño exclusivo que captura la esencia mágica de Rapunzel" width={300} height={300} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"/>
            <div class="absolute inset-0 bg-linear-to-t from-black/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>
          <h3 class="mb-2 font-main font-semibold text-xl">Ramo Encantado</h3>
          <p class="text-text-muted text-base font-light">Inspiración floral con destellos dorados y violetas para tu propia historia.</p>
        </div>
        <div class="p-6 rounded-2xl transition-all duration-300 hover:-translate-y-1.5 hover:shadow-lg glass">
          <div class="h-60 rounded-xl mb-5 overflow-hidden shadow-inner relative">
            <Image src={Lirios} alt="Diseño exclusivo que captura la esencia mágica de Rapunzel" width={300} height={300} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"/>
            <div class="absolute inset-0 bg-linear-to-t from-black/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>
          <h3 class="mb-2 font-main font-semibold text-xl">Lirios de Medianoche</h3>
          <p class="text-text-muted text-base font-light">Elegancia en azul: cuatro lirios majestuosos de presencia única.</p>
        </div>
      </div>
      <div class="mt-12">
        <a href="/galeria" class="btn btn-outline">Ver galería completa</a>
      </div>
    </div>
  </section>
</Layout>
