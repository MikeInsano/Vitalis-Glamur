---
import Layout from '../layouts/Layout.astro';

const productos = [
  { nombre: "Tulipán", precio: 60, isAccesorio: false },
  { nombre: "Lirio", precio: 70, isAccesorio: false },
  { nombre: "Rosa", precio: 50, isAccesorio: false },
  { nombre: "Gerbera", precio: 55, isAccesorio: false },
  { nombre: "Jacinto", precio: 40, isAccesorio: false },
  { nombre: "Nubecitas", precio: 40, isAccesorio: true },
  { nombre: "Corazón", precio: 20, isAccesorio: true },
  { nombre: "Eucalipto", precio: 35, isAccesorio: true },
];

const flores = productos.filter(p => !p.isAccesorio);
const accesorios = productos.filter(p => p.isAccesorio);
---

<Layout title="Catálogo de Productos">
  <div class="bg-linear-to-br from-primary-dark to-accent pt-24 pb-12 px-6 relative rounded-b-[50%_10%]">
    <div class="container max-w-300 mx-auto text-center">
      <h1 class="text-[2.5rem] md:text-[3.5rem] text-white font-main font-semibold leading-tight m-0">Catálogo De Flores Eternas</h1>
      <p class="text-xl text-white/90 mt-4">Personaliza a tu gusto por colores</p>
    </div>
  </div>

  <section class="py-16 px-6">
    <div class="container max-w-300 mx-auto text-center mb-16">
      <span class="bg-white py-1.5 px-4 rounded-full font-bold inline-block shadow-sm text-accent">Tamaños Disponibles</span>
      <h2 class="text-3xl md:text-4xl text-text-main font-main font-semibold mt-4 mb-4">Ramos Eternos</h2>
      <p class="text-text-muted mb-8 text-lg">Regálalo en tamaño: Grande, Mediano, Pequeño, o Individual <br/> Ideal para: Cumpleaños, Regalos, Días especiales y Aniversarios.</p>
    </div>

    <!-- Sección Flores -->
    <div class="container max-w-300 mx-auto mb-16">
      <h3 class="text-[1.8rem] text-primary-dark mb-8 border-b-2 border-dashed border-primary-light pb-2 inline-block font-main font-semibold">Escoge Tu Flor Eterna</h3>
      <div class="grid grid-cols-[repeat(auto-fill,minmax(250px,1fr))] gap-8">
        {flores.map((flor) => (
          <div class="rounded-2xl overflow-hidden transition-all duration-300 flex flex-col hover:-translate-y-2 hover:shadow-lg glass animate-fade-in">
            <!-- Simulación de imagen -->
            <div class="h-55 bg-cover bg-center bg-linear-to-br from-[#ffd1dc] to-[#ff8fab]"></div>
            <div class="p-6 grow flex col">
              <h4 class="text-xl font-main font-semibold mb-1">{flor.nombre}</h4>
              <p class="text-text-muted text-sm mb-6 grow">Varios Colores</p>
              <div class="flex justify-between items-center mt-auto">
                <span class="text-xl font-bold text-primary-dark">${flor.precio} MXN</span>
                <button class="btn btn-primary add-to-cart py-1.5! px-4! text-sm!" data-name={flor.nombre} data-price={flor.precio}>
                  Agregar
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Sección Accesorios -->
    <div class="container max-w-300 mx-auto mb-16">
      <h3 class="text-[1.8rem] text-primary-dark mb-8 border-b-2 border-dashed border-primary-light pb-2 inline-block font-main font-semibold">Escoge Tu Accesorio Eterno</h3>
      <div class="grid grid-cols-[repeat(auto-fill,minmax(250px,1fr))] gap-8">
        {accesorios.map((acc) => (
          <div class="rounded-2xl overflow-hidden transition-all duration-300 flex flex-col hover:-translate-y-2 hover:shadow-lg glass animate-fade-in">
            <div class="h-55 bg-cover bg-center bg-linear-to-br from-secondary to-primary-light"></div>
            <div class="p-6 grow flex col">
              <h4 class="text-xl font-main font-semibold mb-1">{acc.nombre}</h4>
              <p class="text-text-muted text-sm mb-6 grow">Varios Colores</p>
              <div class="flex justify-between items-center mt-auto">
                <span class="text-xl font-bold text-primary-dark">${acc.precio} MXN</span>
                <button class="btn btn-outline add-to-cart py-1.5! px-4! text-sm!" data-name={acc.nombre} data-price={acc.precio}>
                  Agregar
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

  </section>
</Layout>

<script>
  // Script rápido para interactividad básica carrito
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.add-to-cart');
    let cartCount = 0;
    const cartCountEl = document.querySelector('.cart-count');
    
    buttons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        cartCount++;
        if(cartCountEl) {
          cartCountEl.textContent = cartCount.toString();
          
          // Animación visual al agregar
          const parent = cartCountEl.parentElement;
          if(parent) {
            parent.style.transform = 'scale(1.3)';
            setTimeout(() => {
              parent.style.transform = 'scale(1)';
            }, 200);
          }
        }
        
        // Efecto del botón
        const target = e.target as HTMLElement;
        const originalText = target.textContent || 'Agregar';
        target.textContent = '¡Añadido!';
        target.style.backgroundColor = 'var(--c-secondary-dark)';
        target.style.color = 'var(--c-text-main)';
        target.style.borderColor = 'var(--c-secondary-dark)';
        
        setTimeout(() => {
          target.textContent = originalText;
          target.style.cssText = ''; // Reset estilar inline
        }, 1500);
      });
    });
  });
</script>
