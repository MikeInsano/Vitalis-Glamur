---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import tulipan from '../assets/productos/tulipan.webp';
import lirio from '../assets/productos/lirio.webp';
import rosa from '../assets/productos/rosa.webp';
import dalia from '../assets/productos/dalia.webp';
import gerbera from '../assets/productos/gerbera.webp';
import spider from '../assets/productos/spider.webp';
import jacinto from '../assets/productos/jacinto.webp';
import nube from '../assets/productos/nube.webp';
import corazon from '../assets/productos/corazon.webp';
import lavanda from '../assets/productos/lavanda.webp';
import rapunzel from '../assets/productos/rapunzel.webp';

const productosRaw = [
  { nombre: "Tulipán", precio: 60, imagen: tulipan },
  { nombre: "Lirio", precio: 70, imagen: lirio },
  { nombre: "Rosa", precio: 50, imagen: rosa },
  { nombre: "Dalia", precio: 60, imagen: dalia },
  { nombre: "Gerbera", precio: 55, imagen: gerbera },
  { nombre: "Spider Lily", precio: 85, imagen: spider, isEspecial: true, },
  { nombre: "Jacinto", precio: 40, imagen: jacinto, isAccesorio: true },
  // { nombre: "Eucalipto", precio: 35, isAccesorio: true },
  { nombre: "Nubecitas", precio: 40, imagen: nube, isAccesorio: true },
  { nombre: "Corazón", precio: 20, imagen: corazon, isAccesorio: true },
  { nombre: "Lavanda", precio: 35, imagen: lavanda, isAccesorio: true },
  { nombre: "Rapunzel", precio: 150, imagen: rapunzel ,isEspecial: true }
];
const productos = productosRaw.map(p => ({
  isAccesorio: false,
  isEspecial: false,
  ...p
}));
const flores = productos.filter(p => !p.isAccesorio && !p.isEspecial);
const accesorios = productos.filter(p => p.isAccesorio);
const especiales = productos.filter(p => p.isEspecial);
---

<Layout title="Catálogo de Productos">
  <div class="bg-linear-to-br from-primary-dark to-primary pt-24 pb-12 px-6 relative rounded-b-[50%_10%]">
    <div class="container max-w-300 mx-auto text-center">
      <h1 class="text-[2.5rem] md:text-[3.5rem] text-white font-main font-semibold leading-tight m-0">Catálogo De Flores Eternas</h1>
      <p class="text-xl text-white/90 mt-4">Personaliza a tu gusto por colores</p>
    </div>
  </div>
  <section class="py-16 px-6">
    <div class="container max-w-300 mx-auto text-center mb-16">
      <span class="bg-white py-1.5 px-4 rounded-full font-bold inline-block shadow-sm text-accent">Tamaños Disponibles</span>
      <h2 class="text-3xl md:text-4xl text-text-main font-main font-semibold mt-4 mb-4">Ramos Eternos</h2>
      <p class="text-text-muted mb-8 text-lg">Regálalo en tamaño: Grande, Mediano, Pequeño, o Individual <br/> Ideal para: Cumpleaños, Regalos, Días especiales y Aniversarios.</p>
    </div>
    <div class="container max-w-300 mx-auto mb-16">
      <h3 class="text-[1.8rem] text-primary-dark mb-8 border-b-2 border-dashed border-primary-light pb-2 inline-block font-main font-semibold">Escoge Tu Flor Eterna</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {flores.map((flor) => (
          <div class="group rounded-3xl overflow-hidden transition-all duration-500 flex flex-col hover:shadow-2xl hover:shadow-primary/20 glass animate-fade-in border border-white/40">
            <div class="relative h-44 md:h-48 overflow-hidden">
              {flor.imagen ? (
                <Image src={flor.imagen} alt={flor.nombre} width={400} height={300} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"/>
              ) : (
                <div class="absolute inset-0 bg-linear-to-br from-[#ffd1dc] to-[#ff8fab] transition-transform duration-700 group-hover:scale-110"></div>
              )}
              <span class="absolute top-3 left-3 bg-white/90 backdrop-blur-md text-primary-dark text-[9px] font-black px-2.5 py-1 rounded-full uppercase tracking-wider shadow-sm">
                Eterna
              </span>
            </div>
            <div class="p-5 flex flex-col flex-1">
              <div class="mb-3">
                <h4 class="text-xl font-main font-bold text-text-main leading-tight group-hover:text-primary transition-colors">
                  {flor.nombre}
                </h4>
                <p class="text-[10px] text-text-muted font-bold uppercase tracking-widest opacity-60 mt-1">
                  Personalizable
                </p>
              </div>
              <div class="flex flex-col gap-4 mt-auto pt-4 border-t border-primary/10">
                <div class="flex justify-between items-end">
                  <div class="flex flex-col">
                    <span class="text-[10px] text-text-muted font-bold uppercase -mb-1">Precio</span>
                    <span class="text-xl font-black text-text-main">
                      ${flor.precio} <span class="text-[10px] font-medium text-text-muted">MXN</span>
                    </span>
                  </div>
                  <button class="btn btn-primary add-to-cart py-2! px-4! rounded-xl! text-[10px]! font-bold! shadow-md active:scale-95 transition-all" data-name={flor.nombre} data-price={flor.precio}>
                    Agregar
                  </button>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
    <div class="container max-w-300 mx-auto mb-16">
      <h3 class="text-[1.8rem] text-primary-dark mb-8 border-b-2 border-dashed border-primary-light pb-2 inline-block font-main font-semibold">Escoge Tu Accesorio Eterno</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {accesorios.map((acc) => (
          <div class="group rounded-3xl overflow-hidden transition-all duration-500 flex flex-col hover:shadow-2xl hover:shadow-secondary/30 glass animate-fade-in border border-white/40">
            <div class="relative h-52 overflow-hidden">
              {acc.imagen ? (
                <Image src={acc.imagen} alt={acc.nombre}width={400} height={300} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"/>
              ) : (
                <div class="absolute inset-0 bg-linear-to-br from-secondary/40 to-primary-light transition-transform duration-700 group-hover:scale-110"></div>
              )}
              <span class="absolute top-3 left-3 bg-white/90 backdrop-blur-md text-primary-dark text-[9px] font-black px-2.5 py-1 rounded-full uppercase tracking-wider shadow-sm">
                Complemento
              </span>
            </div>
            <div class="p-5 flex flex-col flex-1">
              <div class="mb-3">
                <h4 class="text-lg font-main font-bold text-text-main leading-tight group-hover:text-primary-dark transition-colors">
                  {acc.nombre}
                </h4>
                <p class="text-[10px] text-text-muted font-bold uppercase tracking-widest opacity-60 mt-1">
                  Detalles Extras
                </p>
              </div>
              <div class="flex flex-col gap-4 mt-auto pt-4 border-t border-secondary/20">
                <div class="flex justify-between items-end">
                  <div class="flex flex-col">
                    <span class="text-[10px] text-text-muted font-bold uppercase -mb-1">Extra</span>
                    <span class="text-xl font-black text-text-main">
                      ${acc.precio} <span class="text-[10px] font-medium text-text-muted">MXN</span>
                    </span>
                  </div>
                  <button class="btn btn-primary add-to-cart py-2! px-4! rounded-xl! text-[10px]! font-bold! shadow-md active:scale-95 transition-all" data-name={acc.nombre} data-price={acc.precio}>
                    Agregar
                  </button>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
    <div class="container max-w-300 mx-auto mb-16">
      <h3 class="text-[1.8rem] text-primary-dark mb-8 border-b-2 border-dashed border-primary-light pb-2 inline-block font-main font-semibold">Ediciones Especiales</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {especiales.map((acc) => (
          <div class="group rounded-3xl overflow-hidden transition-all duration-500 flex flex-col hover:shadow-2xl hover:shadow-secondary/30 glass animate-fade-in border border-white/40">
            <div class="relative h-52 overflow-hidden">
              {acc.imagen ? (
                <Image src={acc.imagen} alt={acc.nombre}width={400} height={300} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"/>
              ) : (
                <div class="absolute inset-0 bg-linear-to-br from-secondary/40 to-primary-light transition-transform duration-700 group-hover:scale-110"></div>
              )}
              <span class="absolute top-3 left-3 bg-white/90 backdrop-blur-md text-primary-dark text-[9px] font-black px-2.5 py-1 rounded-full uppercase tracking-wider shadow-sm">
                Premium
              </span>
            </div>
            <div class="p-5 flex flex-col flex-1">
              <div class="mb-3">
                <h4 class="text-lg font-main font-bold text-text-main leading-tight group-hover:text-primary-dark transition-colors">
                  {acc.nombre}
                </h4>
                <p class="text-[10px] text-text-muted font-bold uppercase tracking-widest opacity-60 mt-1">
                  Exclusivo Vitalis
                </p>
              </div>
              <div class="flex flex-col gap-4 mt-auto pt-4 border-t border-secondary/20">
                <div class="flex justify-between items-end">
                  <div class="flex flex-col">
                    <span class="text-[10px] text-text-muted font-bold uppercase -mb-1">Inversión</span>
                    <span class="text-xl font-black text-text-main">
                      ${acc.precio} <span class="text-[10px] font-medium text-text-muted">MXN</span>
                    </span>
                  </div>
                  <button class="btn btn-primary add-to-cart py-2! px-4! rounded-xl! text-[10px]! font-bold! shadow-md active:scale-95 transition-all" data-name={acc.nombre} data-price={acc.precio}>
                    Agregar
                  </button>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const addButtons = document.querySelectorAll('.add-to-cart');
    addButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const nombre = target.getAttribute('data-name');
        const precio = parseFloat(target.getAttribute('data-price') || '0');
        window.dispatchEvent(new CustomEvent('add-to-cart', { 
          detail: { nombre, precio } 
        }));
      });
    });
  });
</script>
