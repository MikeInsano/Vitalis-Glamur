---
---

<header id="main-header" class="fixed top-0 left-0 w-full z-50 py-4 transition-all duration-300 glass glass-nav">
  <div class="container max-w-300 mx-auto px-6 flex items-center justify-between">
    <a href="/" class="flex items-center gap-1">
      <span class="font-accent text-accent text-3xl md:text-4xl">Flores</span>
      <span class="font-main font-extrabold text-xl md:text-2xl tracking-tight">Eternas</span>
    </a>

    <nav class="hidden md:flex gap-8">
      <a href="/" class="font-main font-medium text-text-main transition-colors duration-300 relative group hover:text-primary-dark after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 group-hover:after:w-full after:h-0.5 after:bg-primary after:transition-all after:duration-300">Inicio</a>
      <a href="/nosotros" class="font-main font-medium text-text-main transition-colors duration-300 relative group hover:text-primary-dark after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 group-hover:after:w-full after:h-0.5 after:bg-primary after:transition-all after:duration-300">Nosotros</a>
      <a href="/catalogo" class="font-main font-medium text-text-main transition-colors duration-300 relative group hover:text-primary-dark after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 group-hover:after:w-full after:h-0.5 after:bg-primary after:transition-all after:duration-300">Catálogo</a>
      <a href="/personalizacion" class="font-main font-medium text-text-main transition-colors duration-300 relative group hover:text-primary-dark after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 group-hover:after:w-full after:h-0.5 after:bg-primary after:transition-all after:duration-300">Personalizar</a>
      <a href="/galeria" class="font-main font-medium text-text-main transition-colors duration-300 relative group hover:text-primary-dark after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 group-hover:after:w-full after:h-0.5 after:bg-primary after:transition-all after:duration-300">Galería</a>
      <a href="/contacto" class="font-main font-medium text-text-main transition-colors duration-300 relative group hover:text-primary-dark after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 group-hover:after:w-full after:h-0.5 after:bg-primary after:transition-all after:duration-300">Contacto</a>
    </nav>

    <div class="flex items-center gap-4">
      <button class="bg-transparent border-none cursor-pointer relative text-text-main flex items-center justify-center transition-all duration-300 hover:text-primary-dark hover:scale-110" aria-label="Abrir carrito">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
        <span class="absolute -top-2 -right-2 bg-accent text-white text-[10px] font-bold w-4.5 h-4.5 rounded-full flex items-center justify-center">0</span>
      </button>
      
      <button class="bg-transparent border-none cursor-pointer flex text-text-main md:hidden" aria-label="Abrir menú">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('py-2', 'shadow-md');
      header?.classList.remove('py-4');
    } else {
      header?.classList.remove('py-2', 'shadow-md');
      header?.classList.add('py-4');
    }
  });
</script>
